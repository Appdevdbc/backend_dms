<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifikasi Dokumen Disetujui</title>
</head>
<body style="margin:0;padding:0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background-color:#f5f5f5;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f5f5f5;padding:20px 0;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background-color:#ffffff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);overflow:hidden;">
          <tr>
            <td style="background:linear-gradient(135deg,#14532d 0%,#22c55e 100%);padding:30px;">
              <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:600;">DMS COMPLIANCE</h1>
            </td>
          </tr>
          <tr>
            <td style="padding:40px 30px;">
              <h2 style="margin:0 0 20px 0;color:#1f2937;font-size:20px;font-weight:600;">Kepada <%= owner_nama %></h2>
              <p style="margin:0 0 25px 0;color:#4b5563;font-size:15px;line-height:1.6;">
                Dokumen Anda telah <strong>disetujui</strong> oleh arsiparis dan kini berstatus <strong>Tersedia</strong>.
              </p>
              <div style="background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 100%);border-left:4px solid #22c55e;border-radius:6px;padding:20px;margin-bottom:25px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="font-size:14px;color:#374151;">
                  <tr><td style="padding:8px 0;width:180px;font-weight:600;">Nama Dokumen</td><td style="padding:8px 0;width:20px;">:</td><td style="padding:8px 0;"><%= nama_dokumen %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;vertical-align:top;">Catatan</td><td style="padding:8px 0;vertical-align:top;">:</td><td style="padding:8px 0;"><%= catatan || '-' %></td></tr>
                </table>
              </div>
              <p style="margin:0;color:#4b5563;font-size:14px;line-height:1.6;">
                Dokumen Anda sudah dapat diakses melalui sistem DMS Compliance.
              </p>
            </td>
          </tr>
          <tr>
            <td style="background-color:#1e293b;padding:20px 30px;text-align:center;">
              <p style="margin:0;color:#94a3b8;font-size:12px;line-height:1.5;">Email ini dikirim secara otomatis oleh sistem DMS Compliance.<br>Mohon tidak membalas email ini.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
