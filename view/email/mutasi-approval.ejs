<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Approval Mutasi Arsip</title>
</head>
<body style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;background-color:#f4f4f4;">
  <table border="0" cellpadding="0" cellspacing="0" style="width:100%;max-width:650px;margin:20px auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.1);">
    <!-- Header -->
    <tr>
      <td colspan="2" style="background:linear-gradient(135deg,#1e3a8a 0%,#3b82f6 100%);padding:30px;text-align:center;color:#ffffff;">
        <h3 style="margin:0 0 10px 0;font-size:24px;font-weight:700;">DMS COMPLIANCE</h3>
        <p style="margin:0;font-size:14px;opacity:0.9;">Permintaan Persetujuan Mutasi Dokumen</p>
      </td>
    </tr>
    
    <!-- Logo -->
    <tr>
      <td colspan="2" style="padding:20px;text-align:right;background:#f7fafc;">
        <img width="80" src="cid:dbc" style="display:inline-block;">
      </td>
    </tr>
    
    <!-- Greeting -->
    <tr>
      <td colspan="2" style="padding:30px 30px 10px 30px;">
        <p style="margin:0;font-size:16px;color:#2d3748;font-weight:600;">Kepada Yth. <strong><%= recipient_name %></strong>,</p>
      </td>
    </tr>
    
    <!-- Message -->
    <tr>
      <td colspan="2" style="padding:10px 30px 20px 30px;">
        <p style="margin:0;font-size:14px;color:#4a5568;line-height:1.6;">Email ini sebagai pemberitahuan pengajuan mutasi dokumen oleh <strong><%= user_nama %></strong>, <%= user_direktorat %>, <%= user_divisi %>.</p>
      </td>
    </tr>
    
    <!-- Info Card -->
    <tr>
      <td colspan="2" style="padding:0 30px 20px 30px;">
        <table border="0" cellpadding="0" cellspacing="0" style="width:100%;background:linear-gradient(135deg,#f0f9ff 0%,#e0f2fe 100%);border-radius:10px;border-left:4px solid #3b82f6;padding:20px;">
          <tr>
            <td style="width:35%;padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">No. Mutasi</td>
            <td style="width:5%;padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;font-weight:700;"><%= no_mutasi %></td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;vertical-align:top;">Nama Dokumen</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;vertical-align:top;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">
              <ul style="margin:0;padding-left:18px;">
                <% documents.forEach(function(doc) { %>
                  <li style="margin:3px 0;"><%= doc.arsip_name || doc.content_name %></li>
                <% }); %>
              </ul>
            </td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Kategori Dokumen</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;"><%= kategori_dokumen %></td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Status Kategori Dokumen</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;"><%= kategori_keamanan %></td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Jumlah</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;font-weight:700;"><%= jumlah %> dokumen</td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Tanggal Pengajuan</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;"><%= tgl_pengajuan %></td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Tanggal Mutasi</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;"><%= tgl_mutasi %></td>
          </tr>
          <tr>
            <td style="padding:8px 0;font-size:13px;color:#2d3748;font-weight:600;">Diajukan Oleh</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;">:</td>
            <td style="padding:8px 0;font-size:13px;color:#4a5568;"><%= user_nama %></td>
          </tr>
        </table>
      </td>
    </tr>
    
    <!-- Instructions -->
    <tr>
      <td colspan="2" style="padding:10px 30px 20px 30px;">
        <p style="margin:0;font-size:14px;color:#4a5568;line-height:1.6;">Setelah melakukan review atas pengajuan mutasi dokumen, silahkan dilanjutkan untuk memberikan penolakan atau revisi atau persetujuan di DMS Compliance dengan klik link di bawah ini.</p>
      </td>
    </tr>
    
    <!-- CTA Button -->
    <tr>
      <td colspan="2" style="padding:10px 30px 30px 30px;text-align:center;">
        <a href="<%= approval_link %>" target="_blank" style="display:inline-block;padding:14px 35px;background:linear-gradient(135deg,#1e3a8a 0%,#3b82f6 100%);color:#ffffff;text-decoration:none;border-radius:50px;font-weight:600;font-size:15px;box-shadow:0 4px 15px rgba(59,130,246,0.4);">Lihat Detail & Proses Approval</a>
      </td>
    </tr>
    
    <!-- Footer -->
    <tr>
      <td colspan="2" style="background:#1e293b;padding:25px;text-align:center;color:#94a3b8;">
        <p style="margin:0 0 10px 0;font-size:14px;font-weight:700;color:#ffffff;">DMS Legal - Document Management System</p>
        <p style="margin:0;font-size:12px;line-height:1.6;">Email ini dikirim secara otomatis oleh sistem.<br>Mohon tidak membalas email ini.</p>
      </td>
    </tr>
  </table>
</body>
</html>
