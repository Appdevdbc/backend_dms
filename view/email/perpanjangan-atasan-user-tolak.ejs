<!DOCTYPE html>
<html><head><meta charset="utf-8"><style>body{font-family:Arial,sans-serif;font-size:13px;color:#333}.header{background:#C62828;color:#fff;padding:16px 24px}.content{padding:24px}.label{color:#666;font-size:12px}.value{font-weight:bold;margin-bottom:8px}.footer{background:#f5f5f5;padding:12px 24px;font-size:11px;color:#888}</style></head>
<body>
<div class="header"><h2 style="margin:0">NOTIFIKASI PERPANJANGAN DOKUMEN (TOLAK)</h2></div>
<div class="content">
  <p>Yth. <strong><%= peminjam_nama %></strong>,</p>
  <p>Pengajuan perpanjangan dokumen Anda <strong>ditolak</strong> oleh atasan.</p>
  <table style="width:100%;border-collapse:collapse;margin-top:12px">
    <tr><td class="label" style="width:180px">Nomor Tiket</td><td class="value">: <%= no_tiket %></td></tr>
    <tr><td class="label">Nama Dokumen</td><td class="value">: <%= nama_doc %></td></tr>
    <tr><td class="label">Alasan Penolakan</td><td class="value">: <%= alasan %></td></tr>
  </table>
</div>
<div class="footer">Email ini dikirim otomatis oleh sistem. Mohon tidak membalas email ini.</div>
</body></html>
