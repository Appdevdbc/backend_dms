<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifikasi Revisi Dokumen</title>
</head>
<body style="margin:0;padding:0;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background-color:#f5f5f5;">
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f5f5f5;padding:20px 0;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width:600px;background-color:#ffffff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1);overflow:hidden;">
          <tr>
            <td style="background:linear-gradient(135deg,#d97706 0%,#fbbf24 100%);padding:30px;">
              <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:600;">DMS COMPLIANCE</h1>
            </td>
          </tr>
          <tr>
            <td style="padding:40px 30px;">
              <h2 style="margin:0 0 20px 0;color:#1f2937;font-size:20px;font-weight:600;">Kepada <%= owner_nama %></h2>
              <p style="margin:0 0 25px 0;color:#4b5563;font-size:15px;line-height:1.6;">
                Email ini sebagai pemberitahuan permintaan revisi atas unggahan dokumen oleh
                <strong><%= owner_nama %></strong><% if (owner_nik) { %>, <%= owner_nik %><% } %><% if (div_nama) { %>, <%= div_nama %><% } %>.
              </p>
              <div style="background:linear-gradient(135deg,#fffbeb 0%,#fef3c7 100%);border-left:4px solid #d97706;border-radius:6px;padding:20px;margin-bottom:25px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="font-size:14px;color:#374151;">
                  <tr><td style="padding:8px 0;width:180px;font-weight:600;">Nama Arsip</td><td style="padding:8px 0;width:20px;">:</td><td style="padding:8px 0;"><%= nama_dokumen %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Nomor Dokumen</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= content_doc || '-' %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Kode Arsip</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= no_arsip || '-' %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Status Dokumen</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= security || '-' %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Jenis Dokumen</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= chk_jenis || '-' %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Kategori Dokumen</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= arsip_kat || '-' %></td></tr>
                  <tr><td style="padding:8px 0;font-weight:600;">Tanggal Dokumen</td><td style="padding:8px 0;">:</td><td style="padding:8px 0;"><%= tgl_doc || '-' %></td></tr>
                </table>
              </div>
              <div style="background-color:#fffbeb;border:1px solid #fde68a;border-radius:6px;padding:20px;margin-bottom:25px;">
                <p style="margin:0 0 10px 0;color:#92400e;font-weight:600;font-size:14px;">Alasan Revisi:</p>
                <p style="margin:0;color:#78350f;font-size:14px;line-height:1.6;"><%= catatan || '-' %></p>
              </div>
              <p style="margin:0 0 20px 0;color:#4b5563;font-size:14px;line-height:1.6;">
                Harap dilakukan revisi atas rekomendasi dari atasan dengan klik tombol di bawah ini.
              </p>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
                <tr>
                  <td style="border-radius:6px;background:linear-gradient(135deg,#d97706 0%,#f59e0b 100%);text-align:center;">
                    <a href="<%= revisi_link %>" target="_blank" style="display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-weight:600;font-size:15px;">Buka Link Revisi</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="background-color:#1e293b;padding:20px 30px;text-align:center;">
              <p style="margin:0;color:#94a3b8;font-size:12px;line-height:1.5;">Email ini dikirim secara otomatis oleh sistem DMS Compliance.<br>Mohon tidak membalas email ini.</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
